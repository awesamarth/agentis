{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "watchPatterns": [
      "/apps/backend/**",
      "/packages/**",
      "/package.json",
      "/bun.lock",
      "/railway.json"
    ]
  },
  "deploy": {
    "startCommand": "bun run backend:start",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
