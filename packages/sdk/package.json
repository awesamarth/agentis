{
  "name": "@agentis-hq/sdk",
  "version": "0.1.0",
  "description": "Agentis SDK — AI agent payment infrastructure for Solana",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@agentis-hq/core": "workspace:*",
    "@solana/kit": "^2.1.0",
    "@solana/mpp": "^0.5.2",
    "gill": "^0.14.0",
    "mppx": "^0.5.17"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
